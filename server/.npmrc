# pnpm v10 only consults the `onlyBuiltDependencies` setting from this file
# (or pnpm-workspace.yaml in monorepos). The same key inside package.json's
# "pnpm" block is *not* honored for single-project repositories.
# See PR #80/#82 for the history of this struggle.
only-built-dependencies[]=esbuild
auto-install-peers=true
# @ludiars スコープは GitHub Packages から取得 (Vestigium 等)。
# token は env 経由 (local: gh auth token / CI: secrets.GITHUB_TOKEN)。
@ludiars:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
