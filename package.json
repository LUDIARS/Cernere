{
  "name": "cernere",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run env:gen && npx dotenv-cli -- concurrently -n api,web -c green,cyan \"cargo watch -x run\" \"npx dotenv-cli -- npm run dev --prefix frontend\"",
    "dev:server": "npx dotenv-cli -- cargo watch -x run",
    "dev:front": "npx dotenv-cli -- npm run dev --prefix frontend",
    "env:setup": "npx tsx packages/env-cli/src/cli.ts setup",
    "env:test": "npx tsx packages/env-cli/src/cli.ts test",
    "env:gen": "npx tsx packages/env-cli/src/cli.ts env",
    "env:list": "npx tsx packages/env-cli/src/cli.ts list",
    "env:get": "npx tsx packages/env-cli/src/cli.ts get",
    "env:set": "npx tsx packages/env-cli/src/cli.ts set",
    "env:initialize": "npx tsx packages/env-cli/src/cli.ts initialize",
    "env:up": "npx tsx packages/env-cli/src/cli.ts up dev",
    "env:up:prod": "npx tsx packages/env-cli/src/cli.ts up prod",
    "env:up:standalone": "npx tsx packages/env-cli/src/cli.ts up standalone",
    "env:up:standalone:dev": "npx tsx packages/env-cli/src/cli.ts up standalone-dev",
    "env:up:fg": "npx tsx packages/env-cli/src/cli.ts up dev -- --abort-on-container-exit"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0",
    "tsx": "^4.19.0",
    "typescript": "~5.9.3"
  }
}
