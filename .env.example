# ═══════════════════════════════════════════════════════════════
# Cernere — 環境変数テンプレート
#
# このファイルは初回セットアップの参考用です。
# 実際の .env は env-cli で Infisical から自動生成してください。
#
# セットアップ手順:
#   1. npm install
#   2. npm run env:setup     ← 対話形式で Infisical を設定
#   3. npm run env:gen       ← Infisical → .env 生成
#   4. docker compose up -d  ← インフラ起動
#   5. cargo run             ← アプリ起動
#
# .env.secrets  ← Infisical 認証情報 (gitignore 済み)
# .env          ← 自動生成される環境変数 (gitignore 済み)
# ═══════════════════════════════════════════════════════════════

# ─── Infrastructure (Docker Compose 用) ──────────────────────
POSTGRES_USER=cernere
POSTGRES_PASSWORD=cernere
POSTGRES_DB=cernere
POSTGRES_PORT=5432
REDIS_PORT=6379

# ─── Application ─────────────────────────────────────────────
DATABASE_URL=postgres://cernere:cernere@localhost:5432/cernere
REDIS_URL=redis://127.0.0.1:6379
LISTEN_ADDR=0.0.0.0:8080
FRONTEND_URL=http://localhost:5173

# ─── JWT (本番環境では Infisical で管理) ─────────────────────
JWT_SECRET=cernere-dev-secret-change-in-production

# ─── PASETO v4 project-token (Ed25519、 公開鍵署名) ────────────
# 起動: `npx tsx scripts/generate-paseto-keypair.ts` で生成、 出力を貼り付け。
# SECRET_KEY は Cernere の secret store にのみ置く (Hub には絶対に置かない)。
# PUBLIC_KEY は誰でも fetch 可 (GET /.well-known/cernere-public-key で公開)。
# 未設定の場合は project-token は旧 HS256 経路で発行される (互換期間)。
CERNERE_PASETO_SECRET_KEY=
CERNERE_PASETO_PUBLIC_KEY=
CERNERE_PASETO_KID=v1

# ─── GitHub OAuth (optional) ─────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8080/auth/github/callback

# ─── Google OAuth (optional) ─────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback

# ─── AWS MFA (optional) ─────────────────────────────────────
AWS_REGION=ap-northeast-1
AWS_SNS_ENABLED=false
AWS_SES_ENABLED=false
AWS_SES_FROM_EMAIL=noreply@example.com
APP_NAME=Cernere

# ─── Mail (SMTP / SES) ──────────────────────────────────────
# AWS_SES_ENABLED=true の場合は SES が優先される。
# dev は共有インフラ (../infra/docker-compose.yaml) の MailHog を使用:
#   SMTP: localhost:1025 / Web UI: http://localhost:8025
CERNERE_SMTP_HOST=localhost
CERNERE_SMTP_PORT=1025
CERNERE_SMTP_USER=
CERNERE_SMTP_PASS=
CERNERE_MAIL_FROM=noreply@cernere.local

# ─── Infisical Bootstrap (env-cli setup で自動設定) ──────────
# SECRETS_PROVIDER=infisical
# INFISICAL_SITE_URL=https://app.infisical.com
# INFISICAL_PROJECT_ID=
# INFISICAL_ENVIRONMENT=dev
# INFISICAL_CLIENT_ID=
# INFISICAL_CLIENT_SECRET=
